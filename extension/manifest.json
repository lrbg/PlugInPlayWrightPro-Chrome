{
  "manifest_version": 3,
  "name": "PlaywrightPro - Test Recorder",
  "version": "1.0.0",
  "description": "Record Playwright test scripts, manage test cases, run tests locally, and integrate with CI/CD pipelines.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PlaywrightPro",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [],
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/recorder.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
